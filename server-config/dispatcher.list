# SCAIP backend set (setid=1). Kamailio load-balances MESSAGE requests across these.
# transport=tcp so backend traffic uses TCP (reliable, matches TLS/TCP from edge).
# Format: setid destination flags priority
# Algorithm 0 = round-robin. Lower priority = preferred when using priority-based selection.
1 sip:127.0.0.1:5062;transport=tcp 0 0
1 sip:127.0.0.1:5063;transport=tcp 0 0
1 sip:127.0.0.1:5064;transport=tcp 0 0
1 sip:127.0.0.1:5065;transport=tcp 0 0
1 sip:127.0.0.1:5066;transport=tcp 0 0
1 sip:127.0.0.1:5067;transport=tcp 0 0
1 sip:127.0.0.1:5068;transport=tcp 0 0
1 sip:127.0.0.1:5069;transport=tcp 0 0
1 sip:127.0.0.1:5070;transport=tcp 0 0
1 sip:127.0.0.1:5071;transport=tcp 0 0
