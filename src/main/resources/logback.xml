<configuration>
    <!-- Rollbar access token: set ROLLBAR_ACCESS_TOKEN (or scaip.rollbar.accessToken) to enable centralized logging -->
    <property name="ROLLBAR_TOKEN" value="${ROLLBAR_ACCESS_TOKEN:-${scaip.rollbar.accessToken:-}}"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Log in user's home so scaip (or any user) can write without /var/log access -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${user.home}/scaip.log</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${user.home}/scaip.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Rollbar: send WARN and ERROR to centralized logging when token is set -->
    <appender name="ROLLBAR" class="com.rollbar.logback.RollbarAppender">
        <accessToken>${ROLLBAR_TOKEN}</accessToken>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="ROLLBAR"/>
    </root>
</configuration>